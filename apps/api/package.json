{
  "name": "@wakibet/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "dotenv -e ../../.env -e ../../.env.example -- tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e ../../.env -e ../../.env.example -- prisma migrate dev",
    "db:push": "dotenv -e ../../.env -e ../../.env.example -- prisma db push",
    "db:studio": "dotenv -e ../../.env -e ../../.env.example -- prisma studio",
    "db:validate": "dotenv -e ../../.env -e ../../.env.example -- prisma validate",
    "dump:openapi": "tsx scripts/dump-openapi.ts",
    "generate:api-types": "pnpm run dump:openapi && openapi-typescript ../../openapi.json -o ../../packages/shared/src/generated/api.d.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.0",
    "@prisma/client": "^6.1.0",
    "@sentry/node": "^8.47.0",
    "@wakibet/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.2.0",
    "fastify-type-provider-zod": "^4.0.2",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "dotenv-cli": "^11.0.0",
    "openapi-typescript": "^7.4.4",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
