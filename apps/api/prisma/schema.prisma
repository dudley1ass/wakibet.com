generator client {
  provider = "prisma-client-js"
  // Avoid hoisted root node_modules/.prisma on Windows (EPERM renaming query_engine DLL when another process locks it).
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ USERS & AUTH ============

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  username        String   @unique
  passwordHash    String?
  googleId        String?  @unique
  displayName     String
  avatarUrl       String?
  dateOfBirth     DateTime
  country         String
  region          String?
  isEmailVerified Boolean  @default(false)
  isBanned        Boolean  @default(false)
  referredById    String?
  referredBy      User?    @relation("Referrals", fields: [referredById], references: [id])
  referrals       User[]   @relation("Referrals")

  wallet                   Wallet?
  lineups                  Lineup[]
  contestEntries           ContestEntry[]
  sessions                 Session[]
  notifications            Notification[]
  winterFantasyRosters     WinterFantasyRoster[]
  fantasyTournamentLineups FantasyTournamentLineup[]
  lacrosseLineups          LacrosseLineup[]
  wfRosters                WfRoster[]
  wfSeasonScores           WfSeasonScore[]
  articleReactions         ArticleReaction[]
  articlePollVotes         ArticlePollVote[]
  investPortfolios         InvestPortfolio[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([referredById])
}

/**
 * Division-scoped player picks for Winter Springs test schedule (string player names).
 */
model WinterFantasyRoster {
  id                    String              @id @default(cuid())
  userId                String
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  divisionKey           String
  picks                 WinterFantasyPick[]
  /// Tiebreaker (pickleball): user guess for total matches in this division/event schedule.
  predictedTotalMatches Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, divisionKey])
  @@index([userId])
}

model WinterFantasyPick {
  id         String              @id @default(cuid())
  rosterId   String
  roster     WinterFantasyRoster @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  slotIndex  Int
  playerName String
  isCaptain  Boolean             @default(false)

  createdAt DateTime @default(now())

  @@unique([rosterId, slotIndex])
  @@index([rosterId])
}

/**
 * Canonical pickleball fantasy for the live product (`FantasyTournament*`); not salary-cap `Contest`/`Lineup` (see `docs/contest-vs-pickleball-fantasy-lineups.md`). Season / multi-event: one submission per user per tournament (see docs/fantasy-tournament-lineups-spec.md).
 */
model FantasyTournamentLineup {
  id             String                       @id @default(cuid())
  userId         String
  user           User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournamentKey  String
  seasonKey      String                       @default("")
  wakicashBudget Int                          @default(100)
  wakicashSpent  Int                          @default(0)
  status         String                       @default("active")
  eventPicks     FantasyTournamentEventPick[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, tournamentKey, seasonKey])
  @@index([userId])
}

model FantasyTournamentEventPick {
  id                    String                           @id @default(cuid())
  lineupId              String
  lineup                FantasyTournamentLineup          @relation(fields: [lineupId], references: [id], onDelete: Cascade)
  slotIndex             Int
  eventKey              String
  eventLabelRaw         String
  eventLabelDisplay     String?
  format                String                           @default("unknown")
  scheduleDivisionKey   String
  tierCodeAtSave        String?
  firstMatchStartsAt    DateTime?
  lockedAt              DateTime?
  /// MLP-only: single franchise bonus pick for this event (player roster stays primary).
  mlpTeamName           String?
  /// Tiebreaker (pickleball): user guess for total matches in this event.
  predictedTotalMatches Int?
  slots                 FantasyTournamentEventPickSlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([lineupId, eventKey])
  @@unique([lineupId, slotIndex])
  @@index([lineupId])
}

model FantasyTournamentEventPickSlot {
  id          String                     @id @default(cuid())
  eventPickId String
  eventPick   FantasyTournamentEventPick @relation(fields: [eventPickId], references: [id], onDelete: Cascade)
  slotIndex   Int
  playerName  String
  isCaptain   Boolean                    @default(false)

  createdAt DateTime @default(now())

  @@unique([eventPickId, slotIndex])
  @@index([eventPickId])
}

/**
 * Cached schedule bucket metadata for fantasy tournament picker + locks + tiers.
 */
model TournamentEventCatalog {
  id                   String    @id @default(cuid())
  tournamentKey        String
  eventKey             String
  scheduleDivisionKey  String
  eventType            String
  skillLevel           String
  ageBracket           String
  labelRaw             String
  labelDisplay         String?
  format               String    @default("unknown")
  tierCode             String    @default("B")
  wakicashMultiplier   Decimal   @default(1) @db.Decimal(10, 4)
  wakipointsMultiplier Decimal   @default(1) @db.Decimal(10, 4)
  isSelectable         Boolean   @default(true)
  matchCount           Int
  entityCount          Int
  firstMatchStartsAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tournamentKey, eventKey])
  @@index([tournamentKey])
}

// ============ LACROSSE FANTASY (confidence allocation slates) ============

model LacrosseSlate {
  id         String   @id @default(cuid())
  slateKey   String   @unique
  name       String
  seasonYear Int
  sport      String   @default("lacrosse")
  status     String   @default("open")
  isCurrent  Boolean  @default(false)
  lockAt     DateTime
  isClosed   Boolean  @default(false)

  lines   LacrosseSlateLine[]
  lineups LacrosseLineup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([seasonYear, lockAt])
}

model LacrosseSlateLine {
  id         String        @id @default(cuid())
  slateId    String
  slate      LacrosseSlate @relation(fields: [slateId], references: [id], onDelete: Cascade)
  lineKey    String
  pickType   String        @default("team_pick")
  isActive   Boolean       @default(true)
  generation Int           @default(1)
  teamA      String
  teamB      String
  spreadA    Decimal       @db.Decimal(6, 2)
  oddsA      Int
  oddsB      Int
  confidence Int

  picks LacrossePick[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slateId, lineKey])
  @@index([slateId])
}

model LacrosseLineup {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  slateId       String
  slate         LacrosseSlate @relation(fields: [slateId], references: [id], onDelete: Cascade)
  status        String        @default("active")
  spentWakiCash Int           @default(0)
  estReturn     Decimal       @default(0) @db.Decimal(10, 2)
  /**
   * JSON: winner_line_id, side, players[] — 3-player stack tied to winner pick
   */
  stackJson     String?       @db.Text

  picks LacrossePick[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, slateId])
  @@index([slateId])
  @@index([userId])
}

model LacrossePick {
  id         String            @id @default(cuid())
  lineupId   String
  lineup     LacrosseLineup    @relation(fields: [lineupId], references: [id], onDelete: Cascade)
  lineId     String
  line       LacrosseSlateLine @relation(fields: [lineId], references: [id], onDelete: Cascade)
  side       String
  stake      Int
  oddsAtSave Int
  estReturn  Decimal           @default(0) @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([lineupId, lineId])
  @@index([lineId])
}

// ============ PICKS SPOTLIGHT (home + promos; time-windowed tournament labels per sport) ============

model PicksSpotlightWindow {
  id         String   @id @default(cuid())
  sportKey   String
  windowKey  String
  labelShort String
  labelFull  String
  venue      String
  href       String
  startsAt   DateTime
  endsAt     DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sportKey, windowKey])
  @@index([sportKey, startsAt])
}

// ============ WAKI BRACKET FANTASY (normalized; phases 1–3) ============
// Prefix Wf* avoids clashing with DFS models: Tournament, Player, Match, Lineup.

model WfTournament {
  id         String   @id @default(cuid())
  slug       String   @unique
  name       String
  source     String   @default("manual")
  location   String?
  startDate  DateTime @db.Date
  endDate    DateTime @db.Date
  seasonYear Int
  status     String   @default("upcoming")

  events  WfTournamentEvent[]
  rosters WfRoster[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([seasonYear])
  @@index([status])
}

model WfTournamentEvent {
  id                 String       @id @default(cuid())
  tournamentId       String
  tournament         WfTournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  rawLabel           String
  normalizedKey      String
  eventType          String
  skillLabel         String?
  ageBracket         String?
  tier               String       @default("B")
  featured           Boolean      @default(false)
  lockAt             DateTime?
  matchCountEstimate Int?
  teamCount          Int?
  status             String       @default("upcoming")

  entries          WfPersonEventEntry[]
  teams            WfDoublesTeam[]
  fantasyPrices    WfFantasyPrice[]
  rosterSelections WfRosterSelection[]
  bracketMatches   WfBracketMatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tournamentId, normalizedKey])
  @@index([tournamentId])
}

/// Scraped / import identity for bracket fantasy (separate from DFS `Player`).
model WfPerson {
  id       String  @id @default(cuid())
  fullName String
  gender   String?
  age      Int?
  city     String?
  state    String?

  eventEntries     WfPersonEventEntry[]
  teamsAsPlayer1   WfDoublesTeam[]      @relation("WfDoublesTeamPlayer1")
  teamsAsPlayer2   WfDoublesTeam[]      @relation("WfDoublesTeamPlayer2")
  fantasyPrices    WfFantasyPrice[]
  rosterSelections WfRosterSelection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fullName])
}

model WfPersonEventEntry {
  id                String            @id @default(cuid())
  tournamentEventId String
  tournamentEvent   WfTournamentEvent @relation(fields: [tournamentEventId], references: [id], onDelete: Cascade)
  personId          String
  person            WfPerson          @relation(fields: [personId], references: [id], onDelete: Cascade)
  partnerNameRaw    String?
  teamId            String?
  team              WfDoublesTeam?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  sourceStatus      String            @default("registered")
  seed              Int?

  bracketAsEntry1       WfBracketMatch[] @relation("WfBracketMatchEntry1")
  bracketAsEntry2       WfBracketMatch[] @relation("WfBracketMatchEntry2")
  bracketWinnerAsPlayer WfBracketMatch[] @relation("WfBracketMatchWinnerEntry")

  createdAt DateTime @default(now())

  @@unique([tournamentEventId, personId])
  @@index([tournamentEventId])
  @@index([teamId])
}

model WfDoublesTeam {
  id                String            @id @default(cuid())
  tournamentEventId String
  tournamentEvent   WfTournamentEvent @relation(fields: [tournamentEventId], references: [id], onDelete: Cascade)
  teamKey           String
  player1Id         String
  player1           WfPerson          @relation("WfDoublesTeamPlayer1", fields: [player1Id], references: [id], onDelete: Cascade)
  player2Id         String?
  player2           WfPerson?         @relation("WfDoublesTeamPlayer2", fields: [player2Id], references: [id], onDelete: SetNull)
  displayName       String

  entries            WfPersonEventEntry[]
  fantasyPrices      WfFantasyPrice[]
  rosterSelections   WfRosterSelection[]
  bracketAsTeam1     WfBracketMatch[]     @relation("WfBracketMatchTeam1")
  bracketAsTeam2     WfBracketMatch[]     @relation("WfBracketMatchTeam2")
  bracketWinnerTeams WfBracketMatch[]     @relation("WfBracketMatchWinnerTeam")

  createdAt DateTime @default(now())

  @@unique([tournamentEventId, teamKey])
  @@unique([tournamentEventId, player1Id, player2Id])
  @@index([tournamentEventId])
}

/// Singles: `teamId` null. Doubles: `personId` null. Enforce in app / DB CHECK in migration.
model WfFantasyPrice {
  id                String            @id @default(cuid())
  tournamentEventId String
  tournamentEvent   WfTournamentEvent @relation(fields: [tournamentEventId], references: [id], onDelete: Cascade)
  personId          String?
  person            WfPerson?         @relation(fields: [personId], references: [id], onDelete: Cascade)
  teamId            String?
  team              WfDoublesTeam?    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  baseCost          Int
  adjustmentCost    Int               @default(0)
  finalCost         Int

  createdAt DateTime @default(now())

  @@index([tournamentEventId])
  @@index([personId])
  @@index([teamId])
}

/// One roster shell per user per `WfTournament` (parallel to string-key `FantasyTournamentLineup` until merged).
model WfRoster {
  id                 String       @id @default(cuid())
  userId             String
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournamentId       String
  tournament         WfTournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  budgetTotal        Int          @default(100)
  budgetUsed         Int          @default(0)
  maxEventSelections Int          @default(5)
  submittedAt        DateTime?

  selections  WfRosterSelection[]
  cachedScore WfRosterScore?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, tournamentId])
  @@index([userId])
  @@index([tournamentId])
}

model WfRosterSelection {
  id                String            @id @default(cuid())
  rosterId          String
  roster            WfRoster          @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  tournamentEventId String
  tournamentEvent   WfTournamentEvent @relation(fields: [tournamentEventId], references: [id], onDelete: Cascade)
  personId          String?
  person            WfPerson?         @relation(fields: [personId], references: [id], onDelete: SetNull)
  teamId            String?
  team              WfDoublesTeam?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  costPaid          Int
  isCaptain         Boolean           @default(false)
  lockedAt          DateTime?

  scoringEvents WfScoringEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([rosterId, tournamentEventId])
  @@index([rosterId])
}

model WfBracketMatch {
  id                String            @id @default(cuid())
  tournamentEventId String
  tournamentEvent   WfTournamentEvent @relation(fields: [tournamentEventId], references: [id], onDelete: Cascade)
  roundLabel        String

  team1Id String?
  team1   WfDoublesTeam? @relation("WfBracketMatchTeam1", fields: [team1Id], references: [id], onDelete: SetNull)
  team2Id String?
  team2   WfDoublesTeam? @relation("WfBracketMatchTeam2", fields: [team2Id], references: [id], onDelete: SetNull)

  player1EntryId String?
  player1Entry   WfPersonEventEntry? @relation("WfBracketMatchEntry1", fields: [player1EntryId], references: [id], onDelete: SetNull)
  player2EntryId String?
  player2Entry   WfPersonEventEntry? @relation("WfBracketMatchEntry2", fields: [player2EntryId], references: [id], onDelete: SetNull)

  winnerTeamId String?
  winnerTeam   WfDoublesTeam? @relation("WfBracketMatchWinnerTeam", fields: [winnerTeamId], references: [id], onDelete: SetNull)

  winnerPlayerEntryId String?
  winnerPlayerEntry   WfPersonEventEntry? @relation("WfBracketMatchWinnerEntry", fields: [winnerPlayerEntryId], references: [id], onDelete: SetNull)

  scoreText   String?
  status      String    @default("scheduled")
  startedAt   DateTime?
  completedAt DateTime?

  scoringEvents WfScoringEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tournamentEventId])
  @@index([status])
}

model WfScoringEvent {
  id                String            @id @default(cuid())
  rosterSelectionId String
  rosterSelection   WfRosterSelection @relation(fields: [rosterSelectionId], references: [id], onDelete: Cascade)
  bracketMatchId    String?
  bracketMatch      WfBracketMatch?   @relation(fields: [bracketMatchId], references: [id], onDelete: SetNull)
  eventCode         String
  points            Int
  description       String

  createdAt DateTime @default(now())

  @@index([rosterSelectionId])
  @@index([bracketMatchId])
}

model WfRosterScore {
  id               String   @id @default(cuid())
  rosterId         String   @unique
  roster           WfRoster @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  tournamentPoints Int      @default(0)
  rankInTournament Int?

  updatedAt DateTime @updatedAt
}

model WfSeasonScore {
  id                 String @id @default(cuid())
  userId             String
  user               User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  seasonYear         Int
  totalPoints        Int    @default(0)
  tournamentsEntered Int    @default(0)
  currentRank        Int?

  updatedAt DateTime @updatedAt

  @@unique([userId, seasonYear])
  @@index([seasonYear])
}

// ============ VOLLEYBALL SCORING DOMAIN (production structure) ============
// Separate namespace (`Vb*`) avoids collisions with existing DFS `Match` entities.

model VbDivision {
  id   String @id @default(cuid())
  code String @unique
  name String

  teams           VbTeam[]
  standings       VbStanding[]
  tiebreakerRules VbTiebreakerRule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VbTournament {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  startDate DateTime? @db.Date
  endDate   DateTime? @db.Date
  status    String    @default("upcoming")

  matches VbMatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VbTeam {
  id         String     @id @default(cuid())
  teamName   String
  divisionId String
  division   VbDivision @relation(fields: [divisionId], references: [id], onDelete: Restrict)

  players      VbTeamPlayer[]
  matchTeams   VbMatchTeam[]
  wonSets      VbSet[]         @relation("VbSetWinner")
  scoredPoints VbPoint[]       @relation("VbPointScoringTeam")
  wonResults   VbMatchResult[] @relation("VbMatchResultWinner")
  lostResults  VbMatchResult[] @relation("VbMatchResultLoser")
  standings    VbStanding[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([divisionId, teamName])
  @@index([divisionId])
}

model VbPlayer {
  id        String @id @default(cuid())
  firstName String
  lastName  String

  teams  VbTeamPlayer[]
  points VbPoint[]
  stats  VbPlayerStat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lastName, firstName])
}

model VbTeamPlayer {
  teamId   String
  team     VbTeam   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerId String
  player   VbPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([teamId, playerId])
  @@index([playerId])
}

model VbMatch {
  id           String        @id @default(cuid())
  tournamentId String?
  tournament   VbTournament? @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
  round        String
  matchDate    DateTime
  bestOfSets   Int
  status       VbMatchStatus @default(SCHEDULED)

  teams  VbMatchTeam[]
  sets   VbSet[]
  result VbMatchResult?
  points VbPlayerStat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tournamentId, matchDate])
  @@index([status])
}

model VbMatchTeam {
  id      String  @id @default(cuid())
  matchId String
  match   VbMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  teamId  String
  team    VbTeam  @relation(fields: [teamId], references: [id], onDelete: Restrict)
  isHome  Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([matchId, teamId])
  @@index([teamId])
}

model VbSet {
  id            String  @id @default(cuid())
  matchId       String
  match         VbMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  setNumber     Int
  winningTeamId String?
  winningTeam   VbTeam? @relation("VbSetWinner", fields: [winningTeamId], references: [id], onDelete: SetNull)
  team1Score    Int
  team2Score    Int

  points VbPoint[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, setNumber])
  @@index([winningTeamId])
}

model VbPoint {
  id            String      @id @default(cuid())
  setId         String
  set           VbSet       @relation(fields: [setId], references: [id], onDelete: Cascade)
  scoringTeamId String
  scoringTeam   VbTeam      @relation("VbPointScoringTeam", fields: [scoringTeamId], references: [id], onDelete: Restrict)
  playerId      String?
  player        VbPlayer?   @relation(fields: [playerId], references: [id], onDelete: SetNull)
  skillType     VbSkillType
  occurredAt    DateTime    @default(now())

  @@index([setId, occurredAt])
  @@index([scoringTeamId])
  @@index([playerId])
}

model VbMatchResult {
  matchId           String  @id
  match             VbMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  winningTeamId     String
  winningTeam       VbTeam  @relation("VbMatchResultWinner", fields: [winningTeamId], references: [id], onDelete: Restrict)
  losingTeamId      String
  losingTeam        VbTeam  @relation("VbMatchResultLoser", fields: [losingTeamId], references: [id], onDelete: Restrict)
  setsWonWinner     Int
  setsWonLoser      Int
  totalPointsWinner Int
  totalPointsLoser  Int
  pointsAwardedWin  Int?
  pointsAwardedLoss Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([winningTeamId])
  @@index([losingTeamId])
}

model VbStanding {
  id            String     @id @default(cuid())
  divisionId    String
  division      VbDivision @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  teamId        String
  team          VbTeam     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  matchesPlayed Int        @default(0)
  wins          Int        @default(0)
  losses        Int        @default(0)
  pointsFor     Int        @default(0)
  pointsAgainst Int        @default(0)
  setsWon       Int        @default(0)
  setsLost      Int        @default(0)
  rankingPoints Float      @default(0)

  updatedAt DateTime @updatedAt

  @@unique([divisionId, teamId])
  @@index([divisionId, rankingPoints])
}

model VbTiebreakerRule {
  id         String               @id @default(cuid())
  divisionId String
  division   VbDivision           @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  priority   Int
  ruleType   VbTiebreakerRuleType

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([divisionId, priority])
  @@index([divisionId])
}

model VbPlayerStat {
  id       String   @id @default(cuid())
  matchId  String
  match    VbMatch  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId String
  player   VbPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)
  kills    Int      @default(0)
  assists  Int      @default(0)
  blocks   Int      @default(0)
  aces     Int      @default(0)
  digs     Int      @default(0)
  errors   Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, playerId])
  @@index([playerId])
}

model VbScoringRule {
  id            String  @id @default(cuid())
  setsWon       Int
  setsLost      Int
  pointsAwarded Int
  isActive      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([setsWon, setsLost])
}

enum VbMatchStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETE
  CANCELLED
}

enum VbSkillType {
  SERVE
  KILL
  BLOCK
  ERROR
  ACE
}

enum VbTiebreakerRuleType {
  HEAD_TO_HEAD
  SET_RATIO
  POINT_RATIO
  POINT_DIFFERENTIAL
  TOTAL_WINS
  STRENGTH_OF_SCHEDULE
  COIN_TOSS
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String    @unique
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  @@index([userId])
}

// ============ WALLET ============

model Wallet {
  id            String         @id @default(cuid())
  userId        String         @unique
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  cachedBalance Decimal        @default(0) @db.Decimal(20, 4)
  currency      String         @default("DILLS")
  entries       WalletLedger[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

enum LedgerEntryType {
  SIGNUP_BONUS
  DAILY_LOGIN
  REFERRAL_BONUS
  CONTEST_ENTRY
  CONTEST_WINNINGS
  CONTEST_REFUND
  ADMIN_ADJUSTMENT
  PROMO_BONUS
}

model WalletLedger {
  id             String          @id @default(cuid())
  walletId       String
  wallet         Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type           LedgerEntryType
  amount         Decimal         @db.Decimal(20, 4)
  balanceAfter   Decimal         @db.Decimal(20, 4)
  idempotencyKey String          @unique
  contestEntryId String?
  contestEntry   ContestEntry?   @relation(fields: [contestEntryId], references: [id], onDelete: SetNull)
  metadata       Json?
  createdAt      DateTime        @default(now())

  @@index([walletId, createdAt])
}

// ============ PICKLEBALL DOMAIN ============

enum Tour {
  PPA
  MLP
  APP
  OTHER
}

enum MatchFormat {
  SINGLES
  DOUBLES
  MIXED_DOUBLES
}

model Tournament {
  id          String                   @id @default(cuid())
  externalId  String                   @unique
  name        String
  tour        Tour
  startsAt    DateTime
  endsAt      DateTime
  location    String?
  surface     String?
  prizePool   Decimal?                 @db.Decimal(20, 2)
  isFinalized Boolean                  @default(false)
  matches     Match[]
  contests    Contest[]
  players     PlayerTournamentSalary[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([startsAt])
}

model Player {
  id         String    @id @default(cuid())
  externalId String    @unique
  firstName  String
  lastName   String
  fullName   String
  handedness String?
  country    String?
  birthDate  DateTime?
  photoUrl   String?
  isActive   Boolean   @default(true)
  dupr       Decimal?  @db.Decimal(5, 2)

  matches     MatchParticipant[]
  stats       PlayerMatchStat[]
  salaries    PlayerTournamentSalary[]
  lineupSlots LineupSlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lastName, firstName])
}

model PlayerTournamentSalary {
  id           String      @id @default(cuid())
  playerId     String
  player       Player      @relation(fields: [playerId], references: [id])
  tournamentId String
  tournament   Tournament  @relation(fields: [tournamentId], references: [id])
  format       MatchFormat
  salary       Int
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([playerId, tournamentId, format])
  @@index([tournamentId])
}

enum MatchStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
  POSTPONED
}

model Match {
  id           String      @id @default(cuid())
  externalId   String      @unique
  tournamentId String
  tournament   Tournament  @relation(fields: [tournamentId], references: [id])
  round        String
  format       MatchFormat
  scheduledAt  DateTime
  startedAt    DateTime?
  endedAt      DateTime?
  status       MatchStatus @default(SCHEDULED)
  scoreSummary String?

  participants MatchParticipant[]
  stats        PlayerMatchStat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tournamentId])
  @@index([scheduledAt])
  @@index([status])
}

model MatchParticipant {
  id       String   @id @default(cuid())
  matchId  String
  match    Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId String
  player   Player   @relation(fields: [playerId], references: [id])
  side     Int
  isWinner Boolean?

  createdAt DateTime @default(now())

  @@unique([matchId, playerId])
  @@index([matchId])
}

model PlayerMatchStat {
  id       String @id @default(cuid())
  matchId  String
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId String
  player   Player @relation(fields: [playerId], references: [id])

  matchWon        Boolean @default(false)
  setsWon         Int     @default(0)
  setsLost        Int     @default(0)
  totalPointsWon  Int     @default(0)
  totalPointsLost Int     @default(0)
  aces            Int     @default(0)
  winners         Int     @default(0)
  unforcedErrors  Int     @default(0)
  rawStatsJson    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, playerId])
  @@index([playerId])
}

// ============ CONTESTS & LINEUPS ============

enum ContestType {
  SALARY_CAP
  HEAD_TO_HEAD
  SEASON_LONG
}

enum ContestStatus {
  UPCOMING
  LOCKED
  SCORING
  COMPLETED
  CANCELLED
}

enum ContestVisibility {
  PUBLIC
  PRIVATE
}

/// Salary-cap contest entries use generic `Lineup` + wallet ledger flows; pickleball season fantasy uses `FantasyTournamentLineup` instead — see `docs/contest-vs-pickleball-fantasy-lineups.md`.
model Contest {
  id                String            @id @default(cuid())
  name              String
  type              ContestType       @default(SALARY_CAP)
  visibility        ContestVisibility @default(PUBLIC)
  inviteCode        String?           @unique
  tournamentId      String
  tournament        Tournament        @relation(fields: [tournamentId], references: [id])
  salaryCap         Int
  lineupSize        Int
  format            MatchFormat
  entryFee          Int
  maxEntries        Int
  maxEntriesPerUser Int               @default(1)
  minEntriesToStart Int               @default(2)
  prizeStructure    Json
  rakePct           Decimal           @default(10.00) @db.Decimal(5, 2)
  opensAt           DateTime
  locksAt           DateTime
  status            ContestStatus     @default(UPCOMING)

  entries   ContestEntry[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([tournamentId])
  @@index([status, opensAt])
}

model ContestEntry {
  id        String  @id @default(cuid())
  contestId String
  contest   Contest @relation(fields: [contestId], references: [id])
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  lineupId  String  @unique
  lineup    Lineup  @relation(fields: [lineupId], references: [id])

  finalScore Decimal? @db.Decimal(10, 2)
  finalRank  Int?
  payout     Int?

  ledgerEntries WalletLedger[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contestId, userId, lineupId])
  @@index([contestId])
  @@index([userId])
}

enum ArticleReactionType {
  HOT_TAKE
  TERRIBLE_TAKE
  SHARP
  SLEEPER
}

enum ArticlePollOption {
  OVERRATED
  FAIR_VALUE
  SLEEPER
}

model ArticleReaction {
  id           String              @id @default(cuid())
  articleSlug  String
  reactionType ArticleReactionType
  userId       String?
  user         User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  anonId       String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@unique([articleSlug, userId])
  @@unique([articleSlug, anonId])
  @@index([articleSlug, reactionType])
}

model ArticlePollVote {
  id          String            @id @default(cuid())
  articleSlug String
  option      ArticlePollOption
  userId      String?
  user        User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  anonId      String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([articleSlug, userId])
  @@unique([articleSlug, anonId])
  @@index([articleSlug, option])
}

model Lineup {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  name        String?
  totalSalary Int
  slots       LineupSlot[]
  entry       ContestEntry?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model LineupSlot {
  id             String @id @default(cuid())
  lineupId       String
  lineup         Lineup @relation(fields: [lineupId], references: [id], onDelete: Cascade)
  playerId       String
  player         Player @relation(fields: [playerId], references: [id])
  rosterPosition String
  salaryAtLock   Int

  createdAt DateTime @default(now())

  @@unique([lineupId, playerId])
  @@unique([lineupId, rosterPosition])
}

model Notification {
  id     String    @id @default(cuid())
  userId String
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type   String
  title  String
  body   String
  data   Json?
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, readAt])
}

model Job {
  id          String    @id @default(cuid())
  type        String
  status      String
  payload     Json
  result      Json?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([type, status])
}

// ============ PPA TOUR RESULTS (append-only; Wakibet stats / pricing source) ============
// Separate from DFS `Player` / `Tournament`: one row per real-world result row, never overwritten.

model PpaResultPlayer {
  id         Int     @id @default(autoincrement())
  playerKey  String  @unique
  playerName String
  gender     String?
  homeCity   String?
  homeState  String?
  active     String  @default("yes")

  results PpaResultPlayerEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([playerName])
}

model PpaResultTournament {
  id        String    @id
  name      String
  tour      String    @default("PPA")
  location  String?
  startDate DateTime?
  endDate   DateTime?

  events  PpaResultEvent[]
  results PpaResultPlayerEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PpaResultEvent {
  id             String              @id
  tournamentId   String
  tournament     PpaResultTournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  eventName      String
  eventType      String
  genderDivision String

  results PpaResultPlayerEvent[]

  @@index([tournamentId])
}

/// One append-only fact row per player per event (doubles → two rows, same rank/wins/pd).
model PpaResultPlayerEvent {
  id           String              @id @default(cuid())
  playerId     Int
  player       PpaResultPlayer     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  tournamentId String
  tournament   PpaResultTournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  eventId      String
  event        PpaResultEvent      @relation(fields: [eventId], references: [id], onDelete: Cascade)

  partnerName  String?
  rank         Int
  roundsPlayed Int
  wins         Int
  pd           Int
  medal        String?

  createdAt DateTime @default(now())

  @@unique([playerId, eventId])
  @@index([tournamentId, eventId])
  @@index([playerId, createdAt])
}

// ============ INVEST SPORT — Weekly Stock Pick'em ============
// Virtual portfolios only. No real money is invested. Picks lock at market open
// Monday, settle at the close Friday. Prices come from Finnhub (or whichever
// market-data provider is configured server-side).

/// One user's portfolio for a single weekly contest window.
model InvestPortfolio {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Stable key for the contest window, e.g. "invest_weekly_2026_05_11".
  contestKey       String
  /// ISO instants for the contest window (denormalized for queries; source of truth is shared rules).
  lockAt           DateTime
  endAt            DateTime
  /// Marked true once the price-lock job has run for this contest (open prices captured).
  isLocked         Boolean  @default(false)
  /// Marked true once Friday close settlement has run.
  isSettled        Boolean  @default(false)
  /// Final portfolio return % after settlement (null until settled).
  settledReturnPct Float?
  /// Snapshot of total starting portfolio value in virtual USD at lock time.
  startingValueUsd Float?
  /// Snapshot of total ending portfolio value in virtual USD at settle time.
  endingValueUsd   Float?

  positions InvestPortfolioPosition[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, contestKey])
  @@index([contestKey])
  @@index([userId])
}

/// One position (symbol + allocation %) within a portfolio. Per-row snapshots
/// of lock/settle prices are stored here so historical leaderboards remain
/// stable even if the price feed disappears later.
model InvestPortfolioPosition {
  id            String          @id @default(cuid())
  portfolioId   String
  portfolio     InvestPortfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  symbol        String
  /// 0–100 percent of starting virtual cash allocated to this position.
  allocationPct Float
  /// Per-share price at Monday market open (lock). Null until locked.
  lockPriceUsd  Float?
  /// Per-share price at Friday close (settlement). Null until settled.
  endPriceUsd   Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([portfolioId, symbol])
  @@index([portfolioId])
  @@index([symbol])
}

/// Optional price-snapshot history table for auditability / replays.
/// Captures the lock-time and settle-time price for every symbol that
/// participated in a given contest window.
model InvestPriceSnapshot {
  id         String @id @default(cuid())
  contestKey String
  symbol     String
  /// "lock" = Monday open snapshot; "end" = Friday close snapshot.
  kind       String
  priceUsd   Float
  /// Upstream timestamp from the data provider (unix seconds), when available.
  sourceTs   Int?
  /// Provider tag, e.g. "finnhub".
  provider   String @default("finnhub")

  createdAt DateTime @default(now())

  @@unique([contestKey, symbol, kind])
  @@index([contestKey])
}
