# Production / preview: full URL of the API (no trailing slash).
# Example: https://wakibet-com-2.onrender.com
# REQUIRED for `vite build` / Render static — build fails if missing in production mode.
# Leave unset for local `vite dev` only — dev server proxies /api → http://127.0.0.1:3000
VITE_API_BASE=

# Google Sign-In (OAuth 2.0 web client ID — must match GOOGLE_OAUTH_CLIENT_ID on API)
VITE_GOOGLE_CLIENT_ID=

# Public site origin (no trailing slash). Used at runtime for canonical URLs and Open Graph.
# Match your real domain; keep `public/sitemap.xml` and `public/robots.txt` (Sitemap: line) in sync.
# Example: https://wakibet.com   or   https://www.wakibet.com
VITE_SITE_ORIGIN=
