# Copy to .env in this folder for local development.

# PostgreSQL (matches docker-compose.yml)
DATABASE_URL=postgresql://wakibet:wakibet@localhost:5432/wakibet

# Redis (Phase 2+ jobs / cache)
REDIS_URL=redis://127.0.0.1:6379

# API
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development

# Optional error reporting
SENTRY_DSN=

# API JWT signing (required in production)
WAKIBET_JWT_SECRET=

# Contact form + optional signup alerts (Resend)
# Get an API key at https://resend.com — on Render, add RESEND_API_KEY to the API Web Service (not the static site).
#
# Production: verify your domain in Resend, then set e.g.
#   CONTACT_FROM_EMAIL=WakiBet <noreply@yourdomain.com>
#   SUPPORT_EMAIL=you@yourdomain.com
# The default onboarding@resend.dev sender only works for limited test recipients until a domain is verified.
RESEND_API_KEY=
SUPPORT_EMAIL=support@wakibet.com
CONTACT_FROM_EMAIL=WakiBet Contact <onboarding@resend.dev>
ADMIN_NOTIFY_EMAIL=
