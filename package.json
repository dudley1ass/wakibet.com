{
  "name": "wakibet",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo run build --filter=@wakibet/shared --filter=@wakibet/api --filter=@wakibet/web",
    "lint": "turbo lint",
    "render:build": "pnpm install --frozen-lockfile && pnpm --filter @wakibet/shared build && pnpm --filter @wakibet/api build",
    "render:build:web": "pnpm install --frozen-lockfile && pnpm --filter @wakibet/web build",
    "render-build-web": "pnpm run render:build:web",
    "render:start": "pnpm --filter @wakibet/api start",
    "db:generate": "pnpm --filter @wakibet/api exec prisma generate",
    "db:migrate": "pnpm --filter @wakibet/api run db:migrate",
    "db:push": "pnpm --filter @wakibet/api run db:push",
    "db:validate": "pnpm --filter @wakibet/api run db:validate",
    "db:studio": "pnpm --filter @wakibet/api run db:studio",
    "generate:api-types": "pnpm --filter @wakibet/api run generate:api-types"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
